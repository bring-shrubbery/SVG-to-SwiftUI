{
  "name": "figma-to-swiftui",
  "description": "Convert Figma Paths to SwiftUI",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format iife --target es5 --external @figma/plugin-typings",
    "clean": "rm -rf .turbo node_modules dist",
    "lint": "biome check .",
    "format": "biome format ."
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.123.0",
    "@svg-to-swiftui/tsconfig": "workspace:*",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/hast": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/svg-parser": "^2.0.6",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "svg-to-swiftui-core": "workspace:*"
  },
